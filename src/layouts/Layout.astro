---
import { getImage } from 'astro:assets';
import profilePhoto from '../assets/photos/profile-min.png';
import { getDict, localeHref, localeMetadata, locales, siteUrl } from '../i18n';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const site = Astro.site ?? new URL(siteUrl);

const toAbs = (path: string) => new URL(path, site).toString();

const canonical = toAbs(localeHref(locale));

const ogImageAsset = await getImage({
  src: profilePhoto,
  width: 1200,
  height: 1200,
  format: 'jpg',
});
const ogImageUrl = toAbs(ogImageAsset.src);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#f6f6f6" />
    <meta name="description" content={dict.meta.description} />
    <meta name="author" content="Sebastian Garcia" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <link rel="preload" href="/fonts/Inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/NotoSansJP.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonical} />
    {locales.map((loc) => <link rel="alternate" hreflang={loc} href={toAbs(localeHref(loc))} />)}
    <link rel="alternate" hreflang="x-default" href={toAbs('/')} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sebastian Garcia" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={dict.meta.title} />
    <meta property="og:description" content={dict.meta.description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content={dict.about.imageAlt} />
    <meta property="og:locale" content={localeMetadata[locale].ogLocale} />
    {
      locales
        .filter((loc) => loc !== locale)
        .map((loc) => (
          <meta property="og:locale:alternate" content={localeMetadata[loc].ogLocale} />
        ))
    }
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={dict.meta.title} />
    <meta name="twitter:description" content={dict.meta.description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={dict.about.imageAlt} />
    <title>{dict.meta.title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">{dict.nav.skipToContent}</a>
    <slot />
  </body>
</html>
