---
import Metadata from '../components/Metadata.astro';
import { getDict } from '../i18n';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#f6f6f6" />
    <meta name="description" content={dict.meta.description} />
    <meta name="author" content="Sebastian Garcia" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <link rel="preload" href="/fonts/Inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/NotoSansJP.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <Metadata locale={locale} />
    <title>{dict.meta.title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">{dict.nav.skipToContent}</a>
    <slot />
  </body>
</html>
