---
import { Image } from 'astro:assets';
import cloudPhoto from '../assets/photos/cloud.png';
import serverPhoto from '../assets/photos/server.png';
import webPhoto from '../assets/photos/web.png';
import { getDict } from '../i18n';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const { sections, skills, certifications, education, experience, additionalExperience } =
  dict.resume;

const skillCards = [
  { category: skills.backendApis, photo: serverPhoto },
  { category: skills.webMobile, photo: webPhoto },
  { category: skills.cloudDevOpsTools, photo: cloudPhoto },
];
---

<div class="pre__section">
  <section class="resume">
    <div class="resume__txt__section">
      <h2 class="about__txt__title" id="resume">{dict.resume.title}</h2>
      <p class="resume__txt__subtitle">{sections.certifications}</p>
      {
        certifications.map((cert) => (
          <>
            <p class="resume__txt__experience__company">{cert.title}</p>
            <p class="resume__txt__period">{cert.date}</p>
            {cert.verifyUrl ? (
              <p>
                <a href={cert.verifyUrl} target="_blank" rel="noopener noreferrer">
                  {cert.issuer}
                </a>
              </p>
            ) : (
              <p>{cert.issuer}</p>
            )}
            <br />
          </>
        ))
      }
    </div>

    <div class="resume__skills">
      <div class="resume__skills__title">
        <p class="resume__txt__subtitle">{sections.skills}</p>
      </div>
      {
        skillCards.map(({ category, photo }) => (
          <div class="resume__skills__card">
            <Image
              class="resumen__skills__icon"
              src={photo}
              alt={category.alt}
              width={75}
              height={75}
              quality={99}
              loading="lazy"
              decoding="async"
            />
            <div class="resume__skills__card__text">
              <p class="resume__txt__experience__company">{category.label}</p>
              <p class="resume__txt__skill__item">{category.items}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="resume__txt__section">
      <p class="resume__txt__subtitle">{sections.education}</p>
      {
        education.map((item) => (
          <>
            <p class="resume__txt__experience__company">{item.school}</p>
            <p class="resume__txt__period">{item.period}</p>
            <p>{item.degree}</p>
            <br />
          </>
        ))
      }
    </div>
  </section>
  <section class="resume_experience">
    <div>
      <p class="resume__txt__subtitle">{sections.experience}</p>
      {
        experience.map((item, i) => (
          <>
            <p class="resume__txt__experience__company">{item.company}</p>
            <p>
              {item.role}&nbsp;&sol;&nbsp;{item.period}{' '}
            </p>
            <ul class="resume__list">
              {item.bullets.map((bullet) => (
                <li>
                  <p>{bullet}</p>
                </li>
              ))}
            </ul>
            {i !== experience.length - 1 && <hr />}
            <br />
          </>
        ))
      }
      <p class="resume__txt__subtitle">{sections.additionalExperience}</p>
      {
        additionalExperience.map((item) => (
          <>
            <p class="resume__txt__experience__company">{item.company}</p>
            <p>
              {item.role}&nbsp;&sol;&nbsp;{item.period}{' '}
            </p>
            <ul class="resume__list">
              {item.bullets.map((bullet) => (
                <li>
                  <p>{bullet}</p>
                </li>
              ))}
            </ul>
          </>
        ))
      }
    </div>
  </section>

  <p class="page__index">{dict.resume.pageIndex}</p>
</div>
