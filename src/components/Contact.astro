---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/photos/bogota-min.jpg';
import { getDict } from '../i18n';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
---

<div class="pre__section">
  <section class="contact" id="contact">
    <Image
      class="contact__bg"
      src={profilePhoto}
      alt={dict.contact.imageAlt}
      loading="lazy"
      decoding="async"
    />

    <div class="contact__card">
      <h2 class="contact__card__title">{dict.contact.title}</h2>
      <div class="contact__card__links">
        <p>{dict.contact.labels.mail}</p>
        <a href="mailto:hello@sebastiangarcia.net"> hello@sebastiangarcia.net </a>
        <p>{dict.contact.labels.linkedin}</p>
        <a
          href="https://www.linkedin.com/in/sebastiangarcialopez"
          target="_blank"
          rel="noopener noreferrer"
        >
          linkedin.com/in/sebastiangarcialopez
        </a>
        <p>{dict.contact.labels.github}</p>
        <a href="https://www.github.com/seebgar" target="_blank" rel="noopener noreferrer">
          github.com/seebgar
        </a>
      </div>
    </div>
  </section>

  <p class="page__index">{dict.contact.pageIndex}</p>
</div>
