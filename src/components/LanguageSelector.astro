---
import { getDict, localeHref, localeMetadata, locales } from '../i18n';
import type { Locale } from '../i18n/types';

interface Props {
  current: Locale;
}

const { current } = Astro.props;
const dict = getDict(current);
---

<nav class="footer__lang" aria-label={dict.footer.languageNavLabel}>
  <ul>
    {
      locales.map((loc) => {
        const isCurrent = loc === current;
        const { code, name } = localeMetadata[loc];
        return (
          <li>
            <a
              href={localeHref(loc)}
              hreflang={loc}
              aria-current={isCurrent ? 'page' : undefined}
              aria-label={name}
            >
              {code}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
