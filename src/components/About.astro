---
import { Image } from "astro:assets";
import profilePhoto from "../assets/photos/profile-min.png";
import { getDict } from "../i18n";
import type { Locale } from "../i18n/types";

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
---

<div class="pre__section">
    <section class="about" id="about">
        <div class="about__txt__section">
            <h1 class="about__txt__title">{dict.about.title}</h1>
            <p class="about__txt__subtitle">{dict.about.subtitle}</p>
            <p>{dict.about.bio}</p>
        </div>

        <Image
            class="about__image"
            src={profilePhoto}
            alt={dict.about.imageAlt}
            width={400}
            height={600}
            loading="eager"
            decoding="async"
            fetchpriority="high"
        />
    </section>

    <p class="page__index">{dict.about.pageIndex}</p>
</div>
